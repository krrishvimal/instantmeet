# InstantMeet Backend Environment Variables
# Copy this to .env and fill in production values

# Server port
PORT=5000

# CORS origin - set to your frontend domain in production
# e.g., https://instantmeet-ten.vercel.app
CORS_ORIGIN=*

# Supabase Configurations (Database Integration)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your_service_role_secret_key_here

